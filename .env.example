# Public canonical URL. Use HTTPS in production.
NEXT_PUBLIC_APP_URL=https://movecolombia.co

# Supabase: publishable key may be exposed to the browser; secret key is server-only.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Wompi Web Checkout. Never prefix secrets/private keys with NEXT_PUBLIC_.
WOMPI_ENV=sandbox
WOMPI_PUBLIC_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
# Optional for future direct server-to-server Wompi operations; Web Checkout does not require it.
WOMPI_PRIVATE_KEY=

# Optional transactional email through Resend. Keep the key server-only.
RESEND_API_KEY=
EMAIL_FROM=MOVE Colombia <contactateconseda@gmail.com>
OPERATIONS_EMAIL=contactateconseda@gmail.com
WHATSAPP_BUSINESS_PHONE=

# Use separate restricted Google keys: server key for routes, browser key for Maps JS.
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
EXCHANGE_RATE_API_KEY=
USD_COP_FALLBACK_RATE=4000
